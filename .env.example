# ==============================================================================
# TEMPLATE KONFIGURASI ENVIRONTMENT (Salin file ini menjadi .env)
# ==============================================================================

# 1. Konfigurasi FastAPI (Backend API)
API_HOST=0.0.0.0
API_PORT=8000
DEBUG_MODE=True

# 2. Konfigurasi Streamlit (Interactive Dashboard)
STREAMLIT_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# 3. Kredensial / Secret Key (Jika ada integrasi tambahan)
# API_SECRET_KEY=masukkan_api_key_rahasia_disini
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
